{
  "manifest_version": 3,
  "name": "Web-Omni vNext",
  "version": "4.2.0",
  "minimum_chrome_version": "114",
  "description": "Web-Omni page tools, Command Hub, LAN transfer, screen recording, vault, weather, and translation.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "downloads",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content-scripts/youtube-enhancer.js"],
      "run_at": "document_end"
    }
  ],
  "background_color": "#111111",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Web-Omni Home",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "side-panel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lan-transfer/*",
        "vault/*",
        "screen-recorder/*",
        "assets/brand/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "toggle-command-hub": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle Command Hub"
    },
    "sticky-kill": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Remove sticky overlays"
    }
  }
}
